generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  companies Company[]
  examTypes ExamType[]
  doctors   Doctor[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("reception") // admin, doctor, reception
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id       String  @id @default(cuid())
  name     String
  cnpj     String?
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  employees    Employee[]
  appointments Appointment[]
  pcmso        Pcmso?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  JobRisk   JobRisk[]
}

model Employee {
  id       String  @id @default(cuid())
  name     String
  cpf      String?
  position String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  appointments Appointment[]
  exams        EmployeeExam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamType {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  appointments  Appointment[]
  employeeExams EmployeeExam[]

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  RiskExamRequirement RiskExamRequirement[]
}

model Doctor {
  id        String  @id @default(cuid())
  name      String
  crm       String?
  specialty String?
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])

  appointments Appointment[]
  exams        EmployeeExam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id     String   @id @default(cuid())
  date   DateTime
  status String   @default("scheduled")
  notes  String?

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id])

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeExam {
  id String @id @default(cuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id])

  doctorId String?
  doctor   Doctor? @relation(fields: [doctorId], references: [id])

  examDate   DateTime
  validUntil DateTime?

  result ExamResult?

  createdAt DateTime @default(now())
}

model ExamResult {
  id String @id @default(cuid())

  examId String       @unique
  exam   EmployeeExam @relation(fields: [examId], references: [id])

  fitness      String
  restrictions String?

  createdAt DateTime @default(now())
}

model Pcmso {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  year Int

  responsibleDoctor String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiskFactor {
  id   String @id @default(cuid())
  name String

  jobRisks            JobRisk[]
  RiskExamRequirement RiskExamRequirement[]
}

model JobRisk {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  position String

  riskId String
  risk   RiskFactor @relation(fields: [riskId], references: [id])
}

model RiskExamRequirement {
  id String @id @default(cuid())

  riskId String
  risk   RiskFactor @relation(fields: [riskId], references: [id])

  examTypeId String
  examType   ExamType @relation(fields: [examTypeId], references: [id])

  periodicityMonths Int
}
